# ─── Backend ───
FLASK_HOST=127.0.0.1
FLASK_PORT=5000
DATABASE_URI=postgresql://telemetry_user:telemetry_pass@localhost:5432/telemetry_db

# ─── Gunicorn (Production) ───
# Number of worker processes (auto-calculated if not set: 2 × CPU + 1)
# For 1000 users: 4-8 workers recommended
# For 2000 users: 8-12 workers recommended
GUNICORN_WORKERS=4

# ─── Logging ───
# Centralized logging configuration (see backend/logging_config.py)
# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO
# Log file path (rotating file handler)
LOG_FILE=logs/app.log
# Enable/disable file logging (console always enabled)
LOG_TO_FILE=true
# Max log file size before rotation (bytes, default 10 MB)
LOG_MAX_BYTES=10485760
# Number of backup log files to keep
LOG_BACKUP_COUNT=5

# ─── Zinnia Axion Agent ───
BACKEND_URL=http://127.0.0.1:5000
# OPTIMIZED: Poll every 10s (instead of 1s) for 90% less database/network load
# while maintaining same classification accuracy with 6 samples per 60s bucket
POLL_INTERVAL_SEC=10
BATCH_INTERVAL_SEC=60
BUFFER_FILE=tracker/buffer.json
# Unique user identifier — set this to the employee's name or email
# Each laptop's .env should have a different USER_ID
USER_ID=default

# ─── Enterprise: Device Token Auth (Tracker) ───
# Provisioned by IT — each tracker installation gets a unique token.
# Leave empty for demo mode (no auth required).
TRACKER_DEVICE_TOKEN=
# LAN ID auto-detected from USERNAME (Windows) or USER (Unix).
# Override if needed:
LAN_ID=

# ─── Sleep / Wake detection ───
WAKE_THRESHOLD_SEC=30

# ─── Ghost / system apps (ignored when no interaction) ───
GHOST_APPS=loginwindow,UserNotificationCenter,ScreenSaverEngine,WindowServer,SystemUIServer,Dock,Finder,LockScreen,logind

# ─── Privacy: Window Title Mode ───
# Options: full, redacted, off
WINDOW_TITLE_MODE=redacted

# ─── Productivity thresholds (scaled for 60-second buckets / 6 samples with 10s polling) ───
BUCKET_SIZE_SEC=60
CONFIDENCE_THRESHOLD=0.60
PRODUCTIVE_INTERACTION_THRESHOLD=12
PRODUCTIVE_KEYSTROKE_THRESHOLD=6
PRODUCTIVE_MOUSE_THRESHOLD=6

# ─── Reading / Active Presence detection (scaled for 60s buckets) ───
MOUSE_MOVEMENT_THRESHOLD=48
IDLE_AWAY_THRESHOLD=30
MOUSE_MOVEMENT_MIN_SAMPLES=3

# ─── Anti-cheat: Interaction variance detection ───
MIN_ZERO_SAMPLE_RATIO=0.25
MIN_DISTINCT_VALUES=3

# ─── Multi-monitor / Split-screen / PiP distraction detection ───
DISTRACTION_MIN_RATIO=0.3

# ─── Decision tree v2: rule thresholds ───
# Fraction of samples on productive apps to classify as productive (70%)
PRODUCTIVE_DOMINANT_RATIO=0.70
# Fraction of samples on non-productive apps to classify as non-productive (66.67%)
NON_PROD_DOMINANT_RATIO=0.6667
# Fraction of samples in meeting app to trigger meeting override (50%)
MEETING_DOMINANT_RATIO=0.50
DISTRACTION_CONFIDENCE_MULT=0.70
NON_PROD_MIX_WEIGHT=0.50
ANTI_CHEAT_CONFIDENCE_MULT=0.30

# ─── Meeting apps (always productive when in foreground) ───
MEETING_APPS=zoom,microsoft teams,google meet,webex,facetime,slack huddle,discord call,skype,around,tuple,gather

# ─── Browser apps (website-level breakdown in dashboard) ───
BROWSER_APPS=safari,google chrome,chrome,firefox,microsoft edge,msedge,brave browser,brave,arc,chromium,opera

# ─── App classification ───
# Productive apps (if dominant ≥50%, bucket classified as productive)
# Examples: IDEs, code editors, design tools, productivity software
PRODUCTIVE_APPS=visual studio code,vscode,pycharm,intellij,android studio,xcode,sublime text,atom,vim,emacs,cursor,figma,sketch,adobe photoshop,adobe illustrator,blender,unity,unreal engine,docker,postman,tableau,excel,word,powerpoint,outlook,notion,obsidian,roam research,jira,confluence,linear,asana,trello,monday.com

# Non-productive apps (if dominant ≥66.67%, bucket classified as non-productive)
# Examples: Social media, streaming, gaming
NON_PRODUCTIVE_APPS=youtube,netflix,reddit,twitter,x.com,instagram,facebook,tiktok,twitch,discord,spotify,steam,epic games,league of legends,fortnite,valorant,minecraft,roblox

# ─── Data Retention ───
DATA_RETENTION_DAYS=14

# ─── Timezone ───
TIMEZONE=Asia/Kolkata

# ─── Data Minimization ───
DROP_TITLES=false
TITLE_SCRUB_PATTERNS=

# ─── Rate Limiting & Input Validation ───
MAX_REQUEST_SIZE_KB=512
RATE_LIMIT_PER_DEVICE=120/minute
RATE_LIMIT_ADMIN_LOGIN=5/minute
RATE_LIMIT_ADMIN_MUTATION=30/minute

# ─── Enterprise Hardening ───
# Master toggle: true = demo mode (no auth, open dashboards, good for prototyping)
#                false = production mode (SSO, device auth, team isolation enforced)
DEMO_MODE=true

# Flask session signing key — REQUIRED when DEMO_MODE=false
# Generate one: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=

# Legacy admin credentials — used only if OIDC is not configured
ADMIN_USERNAME=admin
ADMIN_PASSWORD=

# ─── OIDC SSO Configuration (Admin Portal) ───
# Set these to enable SSO login for managers via Azure AD, Okta, etc.
# The issuer URL should support .well-known/openid-configuration discovery.
OIDC_ISSUER_URL=
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=
OIDC_REDIRECT_URI=http://localhost:5000/admin/callback
OIDC_SCOPES=openid profile email

# ─── Break-Glass Emergency Admin Login ───
# Disabled by default. Only enable for emergency scenarios.
# When enabled, allows password-based admin login from allowlisted IPs.
ADMIN_BREAK_GLASS=false
ADMIN_BREAK_GLASS_IPS=127.0.0.1

# ─── CORS ───
# Comma-separated list of allowed origins.
CORS_ALLOWED_ORIGINS=http://localhost:8501,http://localhost:8502

# ─── Session ───
SESSION_COOKIE_SECURE=false
SESSION_COOKIE_SAMESITE=Lax
PERMANENT_SESSION_LIFETIME_MINUTES=30

# ─── AI Summary & Executive Report ───
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# ─── Frontend ───
API_BASE_URL=http://127.0.0.1:5000
